# Copy this file to .env.local and fill in real values when ready to
# connect Stripe and Printify. Do not commit .env.local.

# Stripe — used in app/api/checkout/route.ts once the real integration replaces the stub
STRIPE_SECRET_KEY=

# Printify — used in lib/products.ts once mock data is replaced with a live fetch
PRINTIFY_API_KEY=
PRINTIFY_SHOP_ID=

# Resend — used in app/api/contact/route.ts to send contact form submissions
# to support@wearminimal.eu. Get a key at https://resend.com/api-keys
RESEND_API_KEY=
